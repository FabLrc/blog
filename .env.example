# ==============================================
# DOCKER COMPOSE ENVIRONMENT VARIABLES
# ==============================================

# ==============================================
# BACKEND (STRAPI)
# ==============================================

# Secrets Strapi - GÉNÉRER DES VALEURS UNIQUES EN PRODUCTION
# Commande: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_KEYS=your-app-key-1,your-app-key-2,your-app-key-3,your-app-key-4
API_TOKEN_SALT=your-api-token-salt
ADMIN_JWT_SECRET=your-admin-jwt-secret
TRANSFER_TOKEN_SALT=your-transfer-token-salt
JWT_SECRET=your-jwt-secret

# URL publique de Strapi (utilisée par le backend)
PUBLIC_STRAPI_URL=http://localhost:1337

# ==============================================
# FRONTEND (NEXT.JS)
# ==============================================

# URL de l'API Strapi accessible depuis le frontend
# En local: http://localhost:1337
# En production: https://api.votre-domaine.com
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# ==============================================
# NOTES
# ==============================================
# 1. En développement local: utilisez localhost
# 2. En production Docker:
#    - NEXT_PUBLIC_STRAPI_URL doit pointer vers l'URL publique de votre API
#    - PUBLIC_STRAPI_URL doit aussi pointer vers cette URL publique
# 3. Les secrets doivent être différents entre dev et production
# 4. Ne commitez JAMAIS ce fichier avec de vraies valeurs
